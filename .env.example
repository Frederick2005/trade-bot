# ── Binance ───────────────────────────────────────────────────────────────────
# Get testnet keys from: https://testnet.binancefuture.com
# Get live keys from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
# Chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Trading settings ──────────────────────────────────────────────────────────
TRADING_MODE=paper
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
RISK_PER_TRADE=0.01
MAX_LEVERAGE=5
DAILY_LOSS_LIMIT=0.03
MAX_DRAWDOWN=0.10
MAX_OPEN_TRADES=10

# "block" (reject a same-side trade on a correlated symbol outright),
# "allow" (let it through at full size), or "reduce_size" (default — let it
# through but halve position size). See app/risk/guards.py's
# _check_correlation() docstring for the reasoning.
CORRELATION_MODE=reduce_size

# ── Timeframes ────────────────────────────────────────────────────────────────
# 3-tier timeframes (AtlasQuant v2): PRIMARY = main trend context (4H),
# SECONDARY = trend confirmation + market structure (1H), EXECUTION = entry
# timing (15M). These are the actual settings used now — SIGNAL_TIMEFRAME /
# TREND_TIMEFRAME below are kept only as a fallback for old .env files and
# are NOT read if the three below are set. If you leave PRIMARY/SECONDARY/
# EXECUTION unset and only have the old two vars, make sure they don't both
# resolve to the same timeframe (e.g. old defaults of SIGNAL=1h/TREND=4h
# would leave SECONDARY=4h and PRIMARY=4h colliding) — safest to just set
# all three explicitly:
PRIMARY_TIMEFRAME=4h
SECONDARY_TIMEFRAME=1h
EXECUTION_TIMEFRAME=15m

# Legacy fallback only (used if PRIMARY/SECONDARY/EXECUTION above are unset)
SIGNAL_TIMEFRAME=1h
TREND_TIMEFRAME=4h

# ── Strategy parameters ───────────────────────────────────────────────────────
RSI_LOWER=45
RSI_UPPER=60
ATR_MULTIPLIER=1.5
MIN_RISK_REWARD=2.0

# ── Decision engine (AtlasQuant v2 multi-stage pipeline) ────────────────────────
# These are starting hypotheses, not validated optima — sweep them against
# real backtest data before trusting a specific number. See
# app/strategy/decision_engine.py's module docstring.
QUALITY_SCORE_THRESHOLD=80
MIN_REWARD_RATIO=3.0
MAX_LOSING_STREAK=2

# ── Notifications ─────────────────────────────────────────────────────────────
WEEKLY_REPORT_DAY=sunday
WEEKLY_REPORT_HOUR=8
HEARTBEAT_HOURS=6